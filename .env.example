# --- Core infra ---
DATABASE_URL=postgresql://studio:studio@localhost:5433/studio_agents?schema=public
REDIS_URL=redis://localhost:6380
# Render sets PORT automatically; API_PORT is for local dev only
PORT=4000
API_PORT=4000
WEB_PORT=5173
LOG_LEVEL=info

# --- Web (production / Render static site) ---
# Leave empty locally (Vite proxies /api). On Render, set to API RENDER_EXTERNAL_URL.
VITE_API_BASE_URL=

# --- Secret encryption (32 bytes base64) ---
SECRETS_KEY_BASE64=replace_with_32_random_bytes_base64

# --- Google Cloud Storage ---
GCS_BUCKET=studio-agents-dev
# Path to service-account JSON OR raw JSON in GCS_CREDENTIALS_JSON
GOOGLE_APPLICATION_CREDENTIALS=
GCS_CREDENTIALS_JSON=
GCS_SIGNED_URL_TTL_SECONDS=3600

# --- Provider keys (optional; can also live in DB ProviderCredential) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_LYRIA_ENABLED=1
GEMINI_MUSIC_MODEL=lyria-3-clip-preview
XAI_API_KEY=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
SHOTSTACK_API_KEY=
SHOTSTACK_BASE_URL=https://api.shotstack.io/edit/v1

# --- Defaults ---
DEFAULT_TENANT_SLUG=demo
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_DURATION_SECONDS=30
