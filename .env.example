# --- Core infra ---
DATABASE_URL=postgresql://studio:studio@localhost:5433/studio_agents?schema=public
REDIS_URL=redis://localhost:6380
API_PORT=4000
WEB_PORT=5173
LOG_LEVEL=info

# --- Secret encryption (32 bytes base64) ---
SECRETS_KEY_BASE64=replace_with_32_random_bytes_base64

# --- Google Cloud Storage ---
GCS_BUCKET=studio-agents-dev
# Path to service-account JSON OR raw JSON in GCS_CREDENTIALS_JSON
GOOGLE_APPLICATION_CREDENTIALS=
GCS_CREDENTIALS_JSON=
GCS_SIGNED_URL_TTL_SECONDS=3600

# --- Provider keys (optional; can also live in DB ProviderCredential) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_LYRIA_ENABLED=0
XAI_API_KEY=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
SHOTSTACK_API_KEY=
SHOTSTACK_BASE_URL=https://api.shotstack.io/edit/v1

# --- Defaults ---
DEFAULT_TENANT_SLUG=demo
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_DURATION_SECONDS=30
