generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs      ProjectRun[]
  providers ProviderCredential[]
  audits    AuditLog[]
  series    Series[]
}

enum RunStatus {
  DRAFT
  RUNNING
  AWAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

enum StageName {
  brief
  script
  audio
  asset
  package_
  render
  series
}

enum StageStatus {
  PENDING
  QUEUED
  RUNNING
  AWAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
  SKIPPED
}

enum ProviderType {
  GEMINI
  LLM
  TTS
  MUSIC
  MEDIA_SEARCH
  VIDEO
  STORAGE
}

enum ArtifactKind {
  brief_input
  brief_output
  script_output
  voice_clip
  music_track
  scene_video_source
  scene_image_source
  scene_reference_frame
  scene_first_frame
  scene_last_frame
  scene_rendered_clip
  final_video
  series_final_video
  package_manifest
  package_instructions
  package_timeline
  package_gemini_render_plan
  gemini_operation
}

model ProjectRun {
  id            String     @id @default(cuid())
  tenantId      String
  status        RunStatus  @default(DRAFT)
  currentStage  StageName?
  brief         Json
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages     StageExecution[]
  artifacts  Artifact[]

  @@index([tenantId, status])
}

model StageExecution {
  id          String      @id @default(cuid())
  runId       String
  stage       StageName
  status      StageStatus @default(PENDING)
  attempts    Int         @default(0)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  run ProjectRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stage])
  @@index([status])
}

model Artifact {
  id        String       @id @default(cuid())
  runId     String
  stage     StageName
  kind      ArtifactKind
  gcsPath   String
  mimeType  String
  sizeBytes Int
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())

  run ProjectRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, stage])
  @@index([runId, kind])
}

model ProviderCredential {
  id            String       @id @default(cuid())
  tenantId      String
  type          ProviderType
  provider      String
  displayName   String
  enabled       Boolean      @default(true)
  priority      Int          @default(10)
  encryptedKey  String?
  config        Json         @default("{}")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, enabled, priority])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
}

model Series {
  id            String   @id @default(cuid())
  tenantId      String
  runIds        String[]
  status        String   @default("DRAFT")
  finalGcsPath  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
