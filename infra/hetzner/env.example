# Copy to infra/hetzner/.env on the Hetzner server:
#   cp infra/hetzner/env.example infra/hetzner/.env

# --- Postgres (internal Docker network) ---
POSTGRES_USER=studio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=studio_agents

# --- Public web port (only web is exposed) ---
HTTP_PORT=80

# --- App secrets ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_KEY_BASE64=

# --- Google Cloud Storage (required for artifacts) ---
GCS_BUCKET=
# Path to service-account JSON on the Hetzner host (recommended — avoids .env quoting issues)
GCS_CREDENTIALS_FILE=/root/gcs-key.json
# Optional inline JSON (leave empty when using GCS_CREDENTIALS_FILE)
GCS_CREDENTIALS_JSON=

# --- Gemini (required for real video pipeline) ---
GEMINI_API_KEY=

# --- Optional ---
LOG_LEVEL=info
GEMINI_LYRIA_ENABLED=0
DEFAULT_TENANT_SLUG=demo
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_DURATION_SECONDS=30
GCS_SIGNED_URL_TTL_SECONDS=3600
