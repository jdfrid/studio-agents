# Copy to infra/hetzner/.env on the Hetzner server:
#   cp infra/hetzner/env.example infra/hetzner/.env

# --- Postgres (internal Docker network) ---
POSTGRES_USER=studio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=studio_agents

# --- Public web port (only web is exposed) ---
HTTP_PORT=80

# --- App secrets ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_KEY_BASE64=

# --- Google Cloud Storage (required for artifacts) ---
GCS_BUCKET=
# Path to service-account JSON on the Hetzner host (recommended — avoids .env quoting issues)
GCS_CREDENTIALS_FILE=/root/gcs-key.json
# Optional inline JSON (leave empty when using GCS_CREDENTIALS_FILE)
GCS_CREDENTIALS_JSON=

# --- Gemini (required for real video pipeline) ---
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_MUSIC_MODEL=lyria-3-clip-preview
GEMINI_VIDEO_MODEL=veo-3.1-fast-generate-preview
# Cheapest Veo tier (drafts):
# GEMINI_VIDEO_MODEL=veo-3.1-lite-generate-preview
# Standard (expensive — ~$0.40/sec):
# GEMINI_VIDEO_MODEL=veo-3.1-generate-preview

# --- Cost controls (budget mode defaults) ---
# TARGET_SCENE_SECONDS=10
# GEMINI_VEO_DURATION_BUCKET=4
# ASSET_MODE=reference_only
# ASSET_MODE=shared_reference
# GEMINI_VEO_RESOLUTION=720p
# GEMINI_VEO_AUDIO=0
# RENDER_OUTPUT_SCALE=480
# STUDIO_BUDGET_MODE=0

# --- Optional ---
LOG_LEVEL=info
GEMINI_LYRIA_ENABLED=0
DEFAULT_TENANT_SLUG=demo
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_DURATION_SECONDS=30
GCS_SIGNED_URL_TTL_SECONDS=3600
